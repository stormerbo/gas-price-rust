{
  "build": {
    "devPath": "http://localhost:8080",
    "distDir": "./static",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "中国油价",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.gasprice.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": ["static"],
      "copyright": "Copyright © 2026",
      "category": "Utility",
      "shortDescription": "中国汽油价格管理系统",
      "longDescription": "一个用于查询和管理中国各省份汽油价格的桌面应用程序，支持实时价格查询、历史数据分析和价格趋势可视化。",
      "macOS": {
        "minimumSystemVersion": "10.15",
        "signingIdentity": null,
        "providerShortName": null,
        "entitlements": null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        },
        "wix": {
          "language": "zh-CN",
          "template": null
        }
      }
    },
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src 'self' http://localhost:* http://127.0.0.1:* http://ip-api.com https://geo.datav.aliyun.com https://www.qiyoujiage.com https://cdn.jsdelivr.net; font-src 'self' data:;"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "中国汽油价格管理",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "decorations": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  }
}
